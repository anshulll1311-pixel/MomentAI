# Backend configuration (copy this file to .env at the repository root)
MOMENTAI_ENVIRONMENT=development
MOMENTAI_API_PREFIX=/api/v1
MOMENTAI_CORS_ORIGINS=http://localhost:3000
MOMENTAI_LOG_LEVEL=INFO
MOMENTAI_MAX_UPLOAD_SIZE_MB=500
MOMENTAI_UPLOAD_DIR=uploads
MOMENTAI_THUMBNAIL_DIR=thumbnails
MOMENTAI_FFPROBE_BINARY=ffprobe
MOMENTAI_FFPROBE_TIMEOUT_SECONDS=30
MOMENTAI_FFMPEG_BINARY=ffmpeg
MOMENTAI_FFMPEG_TIMEOUT_SECONDS=30
MOMENTAI_SCENE_THRESHOLD=0.3
MOMENTAI_MINIMUM_SCENE_DURATION_SECONDS=0.5
MOMENTAI_SCENE_DETECTION_TIMEOUT_SECONDS=120
MOMENTAI_TRANSCRIPT_TEMP_DIR=temp/transcripts
MOMENTAI_WHISPER_MODEL_DIR=temp/whisper-models
MOMENTAI_WHISPER_MODEL_SIZE=tiny.en
MOMENTAI_WHISPER_DEVICE=cpu
MOMENTAI_WHISPER_COMPUTE_TYPE=int8
MOMENTAI_WHISPER_BEAM_SIZE=5
MOMENTAI_AUDIO_EXTRACTION_TIMEOUT_SECONDS=60
MOMENTAI_TRANSCRIPTION_TIMEOUT_SECONDS=600
MOMENTAI_EXPORT_DIR=clips/exports
MOMENTAI_EXPORT_TEMP_DIR=temp/exports
MOMENTAI_EXPORT_FFMPEG_TIMEOUT_SECONDS=300
MOMENTAI_EXPORT_FFPROBE_TIMEOUT_SECONDS=30

# Frontend configuration (also copy this file to frontend/.env.local)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
