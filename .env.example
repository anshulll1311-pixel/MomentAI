# Backend configuration (copy this file to .env at the repository root)
MOMENTAI_ENVIRONMENT=development
MOMENTAI_API_PREFIX=/api/v1
MOMENTAI_CORS_ORIGINS=http://localhost:3000
MOMENTAI_LOG_LEVEL=INFO
MOMENTAI_MAX_UPLOAD_SIZE_MB=500
MOMENTAI_UPLOAD_DIR=uploads
MOMENTAI_FFPROBE_BINARY=ffprobe
MOMENTAI_FFPROBE_TIMEOUT_SECONDS=30

# Frontend configuration (also copy this file to frontend/.env.local)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
